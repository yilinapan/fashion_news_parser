# 環境變數範本
# 複製這個檔案為 .env 並填入真實的值（本機測試用）
# 正式運行時，這些值要存在 GitHub Secrets，不要 commit 到 repo

# Claude API Key（從 https://console.anthropic.com 取得）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Service Account JSON（整個 JSON 字串，從 Google Cloud Console 下載）
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Gmail 地址與應用程式密碼
# App Password 設定路徑：Google 帳號 → 安全性 → 兩步驟驗證 → 應用程式密碼
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Sheet 的連結（讓通知信可以直接點進去）
SHEET_URL=https://docs.google.com/spreadsheets/d/xxxxxxxxxxxxxxxx
